{
  "schemaVersion": 2,
  "preset": "monorepo",
  "workflow": {
    "planDefaults": {
      "allowedPaths": [
        "apps/",
        "packages/",
        "tests/"
      ],
      "requiredCommands": [
        "npm test"
      ],
      "evidencePaths": [
        ".agent-guardrails/evidence/current-task.md"
      ]
    },
    "readBeforeWrite": [
      "AGENTS.md",
      "docs/PROJECT_STATE.md",
      "README.md (if it exists)",
      "apps",
      "packages"
    ],
    "constraints": [
      "Prefer touching one package or app slice at a time.",
      "Do not introduce cross-package coupling without explicit justification.",
      "Keep shared-contract changes paired with downstream updates and tests.",
      "Run type-check (e.g. tsc --noEmit) alongside tests when packages use TypeScript."
    ],
    "definitionOfDone": [
      "Changed packages remain bounded and reviewable.",
      "Behavior changes have tests in the affected package or app.",
      "The task leaves project state and next step accurate."
    ]
  },
  "checks": {
    "maxChangedFilesPerTask": 24,
    "requireTestsWithSourceChanges": true,
    "allowedPaths": [],
    "consistency": {
      "maxChangedFilesPerTask": 24,
      "maxTopLevelEntries": 4,
      "maxBreadthMultiplier": 2,
      "warnOnBroadChanges": true
    },
    "correctness": {
      "requireTestsWithSourceChanges": true,
      "requireCommandsReported": true,
      "requireEvidenceFiles": true
    },
    "risk": {
      "requireReviewNotesForProtectedAreas": true,
      "warnOnInterfaceChangesWithoutContract": true,
      "warnOnConfigOrMigrationChanges": true
    },
    "sourceRoots": [
      "apps",
      "packages"
    ],
    "sourceExtensions": [
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".py"
    ],
    "testRoots": [
      "tests"
    ],
    "testExtensions": [
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".py"
    ],
    "testFileSignals": [
      ".test.",
      ".spec.",
      "test_",
      "_test.py"
    ],
    "mutation": {
      "enabled": false,
      "survivalThreshold": 50,
      "maxMutations": 20,
      "timeoutMs": 15000
    },
    "scope": {
      "violationSeverity": "error",
      "violationBudget": 5
    }
  },
  "protectedAreas": [
    {
      "path": "packages/contracts/",
      "label": "shared contracts",
      "minimumRiskLevel": "medium",
      "requiresReviewNotes": true
    },
    {
      "path": "packages/auth/",
      "label": "shared auth package",
      "minimumRiskLevel": "high",
      "requiresReviewNotes": true
    },
    {
      "path": "infra/",
      "label": "infra configuration",
      "minimumRiskLevel": "medium",
      "requiresReviewNotes": true
    }
  ],
  "productionProfiles": {
    "default-monorepo": {
      "focus": [
        "correctness",
        "maintainability",
        "operability"
      ],
      "validationProfile": "standard"
    },
    "shared-contract-heavy": {
      "focus": [
        "reliability",
        "maintainability",
        "operability"
      ],
      "validationProfile": "strict"
    }
  },
  "nfrPolicies": {
    "security": {
      "evidenceHint": "Mention auth, secrets, permissions, and sensitive-data handling explicitly."
    },
    "dependency": {
      "evidenceHint": "Mention new or upgraded packages, lockfile changes, and dependency impact explicitly."
    },
    "performance": {
      "evidenceHint": "Mention latency, throughput, or hotspot validation in evidence."
    },
    "maintainability": {
      "evidenceHint": "Call out package boundaries and downstream impact in evidence."
    },
    "understanding": {
      "evidenceHint": "Explain the main tradeoffs so future maintainers can follow the change."
    },
    "continuity": {
      "evidenceHint": "Mention reuse targets and any deliberate continuity break in evidence."
    },
    "operability": {
      "evidenceHint": "Mention rollout or rollback notes when shared packages change."
    }
  },
  "languagePlugins": {
    "typescript": [
      "@agent-guardrails/plugin-ts"
    ]
  },
  "criticalPaths": [
    "packages/contracts/",
    "packages/auth/",
    "infra/"
  ],
  "runtimeSurfaces": [
    "apps/",
    "packages/",
    "infra/"
  ],
  "performanceSensitiveAreas": [
    "apps/api/",
    "packages/cache/",
    "packages/queue/"
  ],
  "review": {
    "includeEvidenceSummary": true
  }
}
